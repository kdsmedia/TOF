; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters might change in the future.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=4
_global_script_classes=[]
_global_script_class_icons={

}

[application]

config/name="ToF App"
run/main_scene="res://game.tscn"
config/icon="res://assets/icons/icon128.png"
boot_splash/image="res://assets/splash_screen.png"
boot_splash/bg_color=#ff000000
config/use_custom_user_dir=true
config/custom_user_dir_name="ToF"
run/disable_stdout=false


[autoload]

admob={
"path": "*res://scripts/admob_singleton.gd",
"name": "admob"
}

[debug]

settings/fps/force_fps=60

[display]

window/size/width=1280
window/size/height=720
window/size/fullscreen=false
window/size/resizable=true
window/stretch/mode="disabled"
window/stretch/aspect="keep"
window/handheld/orientation="landscape"

[locale]

translation_remaps={

}
translations=PackedStringArray("res://translations/_imported/translations.en.xl", "res://translations/_imported/translations.fr.xl", "res://translations/_imported/translations.pl.xl", "res://translations/_imported/translations.de.xl", "res://translations/_imported/translations.ja.xl", "res://translations/_imported/translations.ru.xl", "res://translations/_imported/translations.es.xl", "res://translations/_imported/translations.id.xl", "res://translations/_imported/campaign.en.xl", "res://translations/_imported/campaign.fr.xl", "res://translations/_imported/campaign.pl.xl", "res://translations/_imported/campaign.de.xl", "res://translations/_imported/campaign.ja.xl", "res://translations/_imported/campaign.ru.xl", "res://translations/_imported/campaign.es.xl")

[rendering]

quality/driver/driver_name="GLES2"
threads/thread_model=2
environment/default_clear_color=#ff005784
vram_compression/import_etc=false
vram_compression/import_etc2=false
2d/snapping/use_gpu_pixel_snap=true

; Custom project settings
[admob]

app_id="ca-app-pub-6881903056221433~2303799202"
interstitial_ad_id="ca-app-pub-6881903056221433/8350332800"
rewarded_ad_id="ca-app-pub-6881903056221433/4180676017"

[tof]

release_yuri=true
ai_logger=true
api_port=443
api_location=""
api_use_ssl=false
resolution_override=true
pandora_input=false
hud_layout="default"
enable_workshop=true
enable_save_load=true
default_zoom=0.5
selector_offset=0
online=true
map_upload_win=false
hud_allow_overscan=true
mobile_prompt=false
debug_mode=true
